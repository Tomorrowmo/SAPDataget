# ============================================================
#  SAP BW 智能取数平台 —— 环境变量模板
#  复制本文件为 .env 后按你的环境填入真实值
# ============================================================

# ---------- LLM 适配层（LiteLLM） ----------
# 模型 ID 用 LiteLLM 命名规范：provider/model
#   国内推荐（便宜、直连）:
#     LLM_MODEL=deepseek/deepseek-chat
#     DEEPSEEK_API_KEY=sk-...
#   阿里云通义千问:
#     LLM_MODEL=dashscope/qwen-max
#     DASHSCOPE_API_KEY=sk-...
#   Claude (需公网或 Bedrock):
#     LLM_MODEL=anthropic/claude-opus-4-7
#     ANTHROPIC_API_KEY=sk-ant-...
#   OpenAI:
#     LLM_MODEL=openai/gpt-4o
#     OPENAI_API_KEY=sk-...
#   本地 Ollama:
#     LLM_MODEL=ollama/qwen2.5:72b
#     LLM_API_BASE=http://localhost:11434
LLM_MODEL=deepseek/deepseek-chat
LLM_API_BASE=
LLM_API_KEY=
LLM_TIMEOUT=120
LLM_MAX_ITERS=10

# ---------- BW 数据层 ----------
# mock = 本机 mock_data 目录（无 SAP 也能开发）
# live = 真实 SAP BW Gateway
BW_MODE=mock
MOCK_DATA_DIR=./mock_data
MOCK_LATENCY_MS=200          # Mock 模式模拟延迟（0 关闭）

# ---------- Live BW 凭据（BW_MODE=live 时必填） ----------
BW_BASE_URL=https://bw.example.com:8000
BW_USERNAME=ZUSER
BW_PASSWORD=changeme
BW_CLIENT=100
BW_LANGUAGE=ZH
BW_VERIFY_SSL=1
BW_TIMEOUT=60

# ---------- Excel 输出 ----------
OUTPUT_DIR=./data/outputs

# ---------- Skills ----------
SKILLS_DIR=./data/skills

# ---------- Auth ----------
# JWT 签名密钥(HS256)。建议用 `python -c "import secrets; print(secrets.token_urlsafe(48))"` 生成。
# 留空会在每次启动随机生成,服务器重启后所有已登录用户的 cookie 会失效。
AUTH_SECRET=
